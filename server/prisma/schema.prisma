generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  displayName  String      @map("display_name")
  avatarUrl    String?     @map("avatar_url")
  tokenVersion Int         @default(0) @map("token_version")
  aiProvider   String?     @map("ai_provider")
  aiModel      String?     @map("ai_model")
  aiApiKeyEnc  String?     @map("ai_api_key_enc")
  aiApiKeyIv   String?     @map("ai_api_key_iv")
  aiApiKeyTag  String?     @map("ai_api_key_tag")
  aiBaseUrl    String?     @map("ai_base_url")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  projects       Project[]
  exportJobs     ExportJob[]
  assets         Asset[]
  templates      Template[]
  chatSessions   AiChatSession[]
  wizardSessions AiWizardSession[]
  workingMemories AiWorkingMemory[]
  memoryItems     AiMemoryItem[]
  taskPlans       AiTaskPlan[]

  @@map("users")
}

enum ProjectType {
  campaign
  one_shot
  supplement
  sourcebook
}

enum ProjectStatus {
  draft
  in_progress
  review
  published
}

model Project {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  title          String
  description    String        @default("")
  type           ProjectType   @default(campaign)
  status         ProjectStatus @default(draft)
  coverImageUrl  String?       @map("cover_image_url")
  settings       Json          @default("{}")
  content        Json          @default("{}")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exportJobs     ExportJob[]
  chatSessions   AiChatSession[]
  wizardSessions AiWizardSession[]
  assets         Asset[]
  workingMemories AiWorkingMemory[]
  memoryItems     AiMemoryItem[]
  taskPlans       AiTaskPlan[]

  @@index([userId])
  @@map("projects")
}


model Template {
  id            String      @id @default(uuid())
  name          String
  description   String      @default("")
  type          ProjectType @default(campaign)
  content       Json        @default("{}")
  thumbnailUrl  String?     @map("thumbnail_url")
  isSystem      Boolean     @default(false) @map("is_system")
  userId        String?     @map("user_id")
  createdAt     DateTime    @default(now()) @map("created_at")

  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("templates")
}

enum ExportFormat {
  pdf
  epub
  print_pdf
}

enum ExportStatus {
  queued
  processing
  completed
  failed
}

model ExportJob {
  id            String       @id @default(uuid())
  projectId     String       @map("project_id")
  userId        String       @map("user_id")
  format        ExportFormat
  status        ExportStatus @default(queued)
  progress      Int          @default(0)
  outputUrl     String?      @map("output_url")
  errorMessage  String?      @map("error_message")
  createdAt     DateTime     @default(now()) @map("created_at")
  completedAt   DateTime?    @map("completed_at")

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("export_jobs")
}

model Asset {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  projectId   String?  @map("project_id")
  filename    String
  mimeType    String   @map("mime_type")
  url         String
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@map("assets")
}

model AiChatSession {
  id        String          @id @default(uuid())
  projectId String          @map("project_id")
  userId    String          @map("user_id")
  createdAt DateTime        @default(now()) @map("created_at")

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiChatMessage[]

  @@unique([projectId, userId])
  @@map("ai_chat_sessions")
}

model AiWizardSession {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  userId     String   @map("user_id")
  phase      String   @default("questionnaire")
  parameters Json?
  outline    Json?
  sections   Json     @default("[]")
  progress   Int      @default(0)
  errorMsg   String?  @map("error_msg")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("ai_wizard_sessions")
}

model AiChatMessage {
  id        String        @id @default(uuid())
  sessionId String        @map("session_id")
  role      String
  content   String
  blocks    Json?
  createdAt DateTime      @default(now()) @map("created_at")

  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_chat_messages")
}

model AiWorkingMemory {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  bullets   Json     @default("[]")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("ai_working_memories")
}

model AiMemoryItem {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  projectId  String?  @map("project_id")
  type       String
  content    String
  confidence Float    @default(1.0)
  source     String?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, projectId])
  @@map("ai_memory_items")
}

model AiTaskPlan {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  tasks     Json     @default("[]")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("ai_task_plans")
}
