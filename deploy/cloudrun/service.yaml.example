apiVersion: serving.knative.dev/v1
kind: Service
metadata:
  name: dnd-booker
  annotations:
    run.googleapis.com/ingress: all
spec:
  template:
    metadata:
      annotations:
        autoscaling.knative.dev/minScale: "1"
        autoscaling.knative.dev/maxScale: "1"
        run.googleapis.com/execution-environment: gen2
        run.googleapis.com/cpu-throttling: "false"
        run.googleapis.com/startup-cpu-boost: "true"
        run.googleapis.com/network-interfaces: '[{"network":"default","subnetwork":"default"}]'
        run.googleapis.com/vpc-access-egress: private-ranges-only
        run.googleapis.com/container-dependencies: '{"server":["cloudsql-proxy"],"worker":["cloudsql-proxy","server"],"client":["server"]}'
    spec:
      containerConcurrency: 20
      timeoutSeconds: 3600
      serviceAccountName: SERVICE_ACCOUNT@PROJECT_ID.iam.gserviceaccount.com
      containers:
        - name: cloudsql-proxy
          image: gcr.io/cloud-sql-connectors/cloud-sql-proxy:latest
          args:
            - --address=0.0.0.0
            - --port=5432
            - PROJECT_ID:REGION:CLOUD_SQL_INSTANCE
          resources:
            limits:
              cpu: "1"
              memory: 256Mi
          startupProbe:
            tcpSocket:
              port: 5432
            failureThreshold: 30
            periodSeconds: 2
        - name: server
          image: REGION-docker.pkg.dev/PROJECT_ID/REPOSITORY/dnd-booker-server:TAG
          command:
            - sh
            - -c
          args:
            - |
              for i in $(seq 1 20); do
                npx prisma migrate deploy && exec node dist/index.js
                echo "prisma migrate deploy failed; retrying in 5s" >&2
                sleep 5
              done
              exit 1
          env:
            - name: NODE_ENV
              value: production
            - name: PORT
              value: "4000"
            - name: REDIS_HOST
              value: REDIS_IP
            - name: REDIS_PORT
              value: "6379"
            - name: CLIENT_URL
              value: https://YOUR_CLOUD_RUN_URL
            - name: REGISTRATION_ALLOWED_EMAILS
              value: allowed@example.com
            - name: GCS_BUCKET
              value: GCS_BUCKET
            - name: GCS_ASSET_PREFIX
              value: uploads
            - name: GCS_EXPORT_PREFIX
              value: output
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: DATABASE_URL_SECRET
                  key: latest
            - name: REDIS_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: REDIS_PASSWORD_SECRET
                  key: latest
            - name: JWT_SECRET
              valueFrom:
                secretKeyRef:
                  name: JWT_SECRET_SECRET
                  key: latest
            - name: JWT_REFRESH_SECRET
              valueFrom:
                secretKeyRef:
                  name: JWT_REFRESH_SECRET_SECRET
                  key: latest
            - name: AI_KEY_ENCRYPTION_SECRET
              valueFrom:
                secretKeyRef:
                  name: AI_KEY_ENCRYPTION_SECRET_SECRET
                  key: latest
          resources:
            limits:
              cpu: "1"
              memory: 1Gi
          startupProbe:
            httpGet:
              path: /api/health
              port: 4000
            failureThreshold: 30
            periodSeconds: 2
        - name: worker
          image: REGION-docker.pkg.dev/PROJECT_ID/REPOSITORY/dnd-booker-worker:TAG
          env:
            - name: NODE_ENV
              value: production
            - name: REDIS_HOST
              value: REDIS_IP
            - name: REDIS_PORT
              value: "6379"
            - name: SERVER_BASE_URL
              value: http://localhost:4000
            - name: GCS_BUCKET
              value: GCS_BUCKET
            - name: GCS_ASSET_PREFIX
              value: uploads
            - name: GCS_EXPORT_PREFIX
              value: output
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: DATABASE_URL_SECRET
                  key: latest
            - name: REDIS_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: REDIS_PASSWORD_SECRET
                  key: latest
            - name: AI_KEY_ENCRYPTION_SECRET
              valueFrom:
                secretKeyRef:
                  name: AI_KEY_ENCRYPTION_SECRET_SECRET
                  key: latest
          resources:
            limits:
              cpu: "2"
              memory: 4Gi
        - name: client
          image: REGION-docker.pkg.dev/PROJECT_ID/REPOSITORY/dnd-booker-client:TAG
          ports:
            - containerPort: 8080
          env:
            - name: PORT
              value: "8080"
            - name: API_UPSTREAM
              value: localhost:4000
          resources:
            limits:
              cpu: "1"
              memory: 512Mi
  traffic:
    - percent: 100
      latestRevision: true
